{
  "name": "zenborg-mcp",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx index.ts",
    "build": "tsc --outDir dist && echo '{\"type\":\"module\"}' > dist/package.json",
    "build:compile": "bun build index.ts --compile --target=bun --outfile dist/zenborg-mcp",
    "typecheck": "tsc --noEmit",
    "smoke": "pnpm build && node smoke-test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
