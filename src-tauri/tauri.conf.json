{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "zenborg",
  "version": "0.10.0",
  "identifier": "org.rafaba.zenborg",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build:export"
  },
  "app": {
    "windows": [
      {
        "title": "zenborg",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFCMzFCMURCRTMzM0IwQzEKUldUQnNEUGoyN0V4RzFPTHRQRUlkL25jNlo2S29RaGc2eWhCNWNXSXFZVEZhK3VqdFBWZmlyZ20K",
      "endpoints": [
        "https://github.com/Thopiax/zenborg/releases/latest/download/latest.json"
      ]
    }
  }
}
